\"\r\n        titleClass=\"text-success\"\r\n        :checkList=\"checkItems\"\r\n        :imgUrl=\"application\"\r\n        :useList=\"useTabs\"\r\n        visualBadgeText=\"BEST\"\r\n        tabClass=\"px-4.5\"\r\n      >\r\n      </support>\r\n\r\n      <Certificate />\r\n    </div>\r\n  </section>\r\n\r\n  <section class=\"w-full max-w-[1140px] mx-auto mt-25 px-8 max-lg:px-6 max-md:px-4\">\r\n    <TabApplication>\r\n      <template #tab1>\r\n        <Procedure \r\n          :title=\"procedureTitle\" \r\n          :description=\"procedureDescription\" \r\n          :steps=\"procedureSteps\" \r\n          :notices=\"procedureNotices\" \r\n        />\r\n      </template>\r\n\r\n      <template #tab2>\r\n        <IssueReview />\r\n      </template>\r\n\r\n      <template #tab3>\r\n        <Frequent />\r\n      </template>\r\n    </TabApplication>\r\n  </section>\r\n</template>\r\n\r\n<style scoped>\r\n</style>"],"version":3}